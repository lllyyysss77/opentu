{
  "name": "drawnix",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/drawnix/src",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project drawnix --web",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.lib.json --noEmit",
        "cwd": "packages/drawnix"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . && node ./scripts/check-hover-usage.mjs",
        "cwd": "packages/drawnix"
      }
    }
  }
}
